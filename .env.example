# Phase 0 defaults are safe by design.
# Copy this file to .env only when you need local overrides.

QS_APP_NAME="AI Quant Research Platform"
QS_ENVIRONMENT="local"
QS_LOG_LEVEL="INFO"

QS_DRY_RUN=true
QS_PAPER_TRADING=true
QS_LIVE_TRADING_ENABLED=false
QS_NO_LIVE_TRADE_WITHOUT_MANUAL_APPROVAL=true
QS_KILL_SWITCH=true

QS_MAX_POSITION_SIZE=0.05
QS_MAX_DAILY_LOSS=0.02
QS_MAX_DRAWDOWN=0.10
QS_MAX_ORDER_VALUE=10000
QS_MAX_TURNOVER=1.0

# Leave blank unless a future live-readiness checklist explicitly requires it.
QS_MANUAL_LIVE_TRADING_CONFIRMATION=""

# Symbol allow/block lists are JSON arrays. Leave unset to keep them empty.
# QS_ALLOWED_SYMBOLS='["SPY","QQQ"]'
# QS_BLOCKED_SYMBOLS='["BAD"]'

