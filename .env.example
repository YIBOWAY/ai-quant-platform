# Phase 0 defaults are safe by design.
# Copy this file to .env only when you need local overrides.

QS_APP_NAME="AI Quant Research Platform"
QS_ENVIRONMENT="local"
QS_LOG_LEVEL="INFO"

QS_DRY_RUN=true
QS_PAPER_TRADING=true
QS_LIVE_TRADING_ENABLED=false
QS_NO_LIVE_TRADE_WITHOUT_MANUAL_APPROVAL=true
QS_KILL_SWITCH=true

QS_MAX_POSITION_SIZE=0.05
QS_MAX_DAILY_LOSS=0.02
QS_MAX_DRAWDOWN=0.10
QS_MAX_ORDER_VALUE=10000
QS_MAX_TURNOVER=1.0

# Leave blank unless a future live-readiness checklist explicitly requires it.
QS_MANUAL_LIVE_TRADING_CONFIRMATION=""

# Symbol allow/block lists are JSON arrays. Leave unset to keep them empty.
# QS_ALLOWED_SYMBOLS='["SPY","QQQ"]'
# QS_BLOCKED_SYMBOLS='["BAD"]'

# Use "sample" to run without API keys. Use "tiingo" when QS_TIINGO_API_TOKEN is set.
QS_DEFAULT_DATA_PROVIDER="sample"
QS_DATA_DIR="data"
QS_PARQUET_DIR="data/parquet"
QS_DUCKDB_PATH="data/quant_system.duckdb"
QS_REPORTS_DIR="reports"

# Keep real credentials only in .env. Never commit .env.
QS_FINNHUB_API_KEY=""
QS_ALPHA_VANTAGE_API_KEY=""
QS_TIINGO_API_TOKEN=""
QS_TWELVEDATA_API_KEY=""
QS_POLYGON_API_KEY=""
QS_NEWSAPI_KEY=""
QS_TWITTER_API_KEY=""
QS_TWITTER_API_KEY_SECRET=""
QS_TWITTER_BEARER_TOKEN=""

# Optional Phase 7 Agent LLM routing. Defaults to deterministic offline stub.
# Both QS_LLM_* and LLM_* env names are accepted.
QS_LLM_PROVIDER="stub"
QS_LLM_API_KEY=""
QS_LLM_BASE_URL=""
QS_LLM_MODEL=""
QS_LLM_TIMEOUT=60

# Optional Phase 11 Polymarket read-only research settings.
# Defaults are safe: sample provider, read-only only, no credentials.
QS_PREDICTION_MARKET_PROVIDER="sample"
QS_POLYMARKET_GAMMA_BASE_URL="https://gamma-api.polymarket.com"
QS_POLYMARKET_CLOB_BASE_URL="https://clob.polymarket.com"
QS_POLYMARKET_REQUEST_TIMEOUT_SECONDS=10
QS_POLYMARKET_MAX_RETRIES=2
QS_POLYMARKET_RATE_LIMIT_PER_SECOND=2.0
QS_POLYMARKET_CACHE_DIR="data/prediction_market"
QS_POLYMARKET_READ_ONLY=true
